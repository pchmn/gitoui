{
  "name": "@gitoui/desktop",
  "version": "0.0.0",
  "description": "A calm, fast desktop git client where the commit graph is the protagonist.",
  "author": "pchmn",
  "repository": "https://github.com/pchmn/gitoui",
  "private": true,
  "type": "module",
  "main": "out/main/index.js",
  "imports": {
    "#ipc/*": "./src/ipc/*.ts",
    "#preload/*": "./src/preload/*.ts",
    "#renderer/*": "./src/renderer/src/*"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "build:app": "electron-vite build && electron-builder",
    "build:mac": "electron-vite build && electron-builder --mac",
    "build:win": "electron-vite build && electron-builder --win",
    "build:linux": "electron-vite build && electron-builder --linux",
    "start": "electron-vite preview",
    "check-types": "tsgo --build --noEmit tsconfig.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@gitoui/contracts": "workspace:*",
    "@gitoui/core": "workspace:*",
    "@gitoui/ui": "workspace:*",
    "@phosphor-icons/react": "catalog:",
    "@pierre/diffs": "^1.2.12",
    "@tanstack/query-db-collection": "catalog:",
    "@tanstack/react-db": "catalog:",
    "@tanstack/react-query": "catalog:",
    "@tanstack/react-router": "catalog:",
    "@tanstack/react-virtual": "catalog:",
    "effect": "catalog:",
    "electron-store": "^11.0.2",
    "react": "catalog:",
    "react-dom": "catalog:"
  },
  "devDependencies": {
    "@gitoui/tsconfig": "workspace:*",
    "@tailwindcss/vite": "catalog:",
    "@testing-library/react": "^16.3.2",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "42.3.3",
    "electron-builder": "26.8.1",
    "electron-vite": "5.0.0",
    "happy-dom": "^20.10.6",
    "tailwindcss": "catalog:",
    "vite": "^7.0.0",
    "vitest": "catalog:"
  }
}
